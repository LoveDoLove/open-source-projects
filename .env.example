# GitHub API Token (optional, for higher rate limits)
# Get a token at: https://github.com/settings/tokens
# Personal access tokens: Create a "classic" token with 'public_repo' scope (minimum required for public repo access)
# Fine-grained tokens: Select 'Contents' read-only permission for public repositories
# Without token: Limited to 60 API requests per hour per IP
# With token: Up to 5,000 API requests per hour
#
# To use this token when running the metadata fetch script:
# export GITHUB_TOKEN=your_token_here
# node scripts/fetchRepoMetadata.js
#
GITHUB_TOKEN=your_github_token_here
